{
  "name": "saudia-automation",
  "version": "1.1.0",
  "description": "Saudia Airlines booking automation tool",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev:renderer": "webpack serve --config webpack.renderer.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --win --config electron-builder.config.js",
    "pack:extract": "cross-env EXTRACTION_ONLY=1 npm run _pack",
    "_pack": "npm run build && electron-builder --win --config electron-builder.config.js"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "playwright-core": "^1.58.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "css-loader": "^6.8.0",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.0",
    "html-webpack-plugin": "^5.5.0",
    "png-to-ico": "^3.0.1",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.2.3"
  }
}
